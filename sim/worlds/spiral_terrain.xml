<!-- MuJoCo World: spiral0.3_2 螺旋地形场景
     地形 mesh 由 sim/scripts/gen_terrain_mesh.py 生成，
     输出到 sim/assets/meshes/spiral_floor_{0..3}.stl
-->
<mujoco model="spiral_terrain">
  <compiler angle="radian" autolimits="true" meshdir="../assets/meshes"/>

  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <asset>
    <!-- 螺旋地形各楼层 mesh（由 gen_terrain_mesh.py 生成）-->
    <mesh name="floor0" file="spiral_floor_0.stl" scale="1 1 1"/>
    <mesh name="floor1" file="spiral_floor_1.stl" scale="1 1 1"/>
    <mesh name="floor2" file="spiral_floor_2.stl" scale="1 1 1"/>
    <mesh name="floor3" file="spiral_floor_3.stl" scale="1 1 1"/>
    <!-- 坡道 mesh（连接各楼层）-->
    <mesh name="ramp01" file="spiral_ramp_01.stl" scale="1 1 1"/>
    <mesh name="ramp12" file="spiral_ramp_12.stl" scale="1 1 1"/>
    <mesh name="ramp23" file="spiral_ramp_23.stl" scale="1 1 1"/>

    <material name="terrain_mat" rgba=".6 .55 .5 1" reflectance="0.05"/>
    <material name="robot_mat"   rgba=".2 .4 .8 1"/>
    <material name="lidar_mat"   rgba=".0 .8 .8 1"/>
  </asset>

  <worldbody>
    <!-- ── 螺旋地形（静态 mesh）──────────────────────────────────────────── -->
    <body name="terrain" pos="0 0 0">
      <geom name="floor0" type="mesh" mesh="floor0" material="terrain_mat"
            conaffinity="1" condim="3"/>
      <geom name="floor1" type="mesh" mesh="floor1" material="terrain_mat"
            conaffinity="1" condim="3"/>
      <geom name="floor2" type="mesh" mesh="floor2" material="terrain_mat"
            conaffinity="1" condim="3"/>
      <geom name="floor3" type="mesh" mesh="floor3" material="terrain_mat"
            conaffinity="1" condim="3"/>
      <geom name="ramp01" type="mesh" mesh="ramp01" material="terrain_mat"
            conaffinity="1" condim="3"/>
      <geom name="ramp12" type="mesh" mesh="ramp12" material="terrain_mat"
            conaffinity="1" condim="3"/>
      <geom name="ramp23" type="mesh" mesh="ramp23" material="terrain_mat"
            conaffinity="1" condim="3"/>
    </body>

    <!-- ── 机器人（起点：Start Z=0.8m）───────────────────────────────────── -->
    <!-- 起点坐标来自 spiral0.3_2 分析：(10.4, 2.8, 0.8) -->
    <body name="base_link" pos="10.4 2.8 1.3">
      <freejoint name="root"/>

      <!-- 机体：占位（替换为自研 URDF mesh）-->
      <geom name="chassis" type="box" size="0.4 0.3 0.12"
            material="robot_mat" mass="25" conaffinity="1"/>

      <!-- 四条腿（占位，等待自研 URDF）-->
      <geom name="leg_fl" type="capsule" size="0.04" fromto="0.3  0.2 -0.12  0.3  0.2 -0.5"
            rgba=".15 .35 .7 1" mass="1"/>
      <geom name="leg_fr" type="capsule" size="0.04" fromto="0.3 -0.2 -0.12  0.3 -0.2 -0.5"
            rgba=".15 .35 .7 1" mass="1"/>
      <geom name="leg_rl" type="capsule" size="0.04" fromto="-.3  0.2 -0.12 -.3  0.2 -0.5"
            rgba=".15 .35 .7 1" mass="1"/>
      <geom name="leg_rr" type="capsule" size="0.04" fromto="-.3 -0.2 -0.12 -.3 -0.2 -0.5"
            rgba=".15 .35 .7 1" mass="1"/>

      <!-- Livox MID-360（机体顶部中央，高出 0.2m）-->
      <body name="lidar_link" pos="0 0 0.32">
        <geom name="lidar_housing" type="cylinder" size="0.06 0.05"
              material="lidar_mat" mass="0.5"/>
        <!-- 连接杆 -->
        <geom name="lidar_pole" type="capsule" size="0.02"
              fromto="0 0 0  0 0 -0.12" rgba=".3 .3 .3 1" mass="0.1"/>
      </body>

      <inertial pos="0 0 0" mass="25" diaginertia="0.8 1.2 1.2"/>
    </body>

    <!-- ── 目标点标记（Goal: -47.8, -28.6, 20.2）────────────────────────── -->
    <body name="goal_marker" pos="-47.8 -28.6 20.2">
      <geom name="goal_sphere" type="sphere" size="0.5"
            rgba="0.8 0.1 0.1 0.5" conaffinity="0" contype="0"/>
    </body>

    <!-- ── 光源 ─────────────────────────────────────────────────────────── -->
    <light name="sun"    pos="0 0 50"  dir="0 0 -1"   diffuse="0.8 0.8 0.8"/>
    <light name="fill"   pos="0 0 30"  dir="0.3 0 -1" diffuse="0.3 0.3 0.3"/>
  </worldbody>

</mujoco>
