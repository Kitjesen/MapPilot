<!--
  MapPilot Industrial Factory Scene
  ==================================
  Multi-level factory for quadruped robot 3D navigation.

  Building footprint: 80m(X) × 55m(Y)   Total height: 13.5m (4 usable levels)
  Outdoor yard: extends to X=-15~95, Y=-15~75

  ┌─── Level RF  Z=13.5m ─── Roof Platform ────────────────────┐
  │    X=48~80, Y=40~55 │  HVAC, antennas, safety railing       │
  ├─── Level M2  Z= 9.0m ─── Control Room ─────────────────────┤
  │    X=48~80, Y=28~55 │  Control panels, observation windows  │
  ├─── Level M1  Z= 4.5m ─── Mezzanine ───────────────────────┤
  │    X=48~80, Y=0~55  │  Catwalk (X=0~10, Y=28~55), bridge   │
  ├─── Level G0  Z= 0.0m ─── Main Production + Warehouse ──────┤
  │    Main Hall X=0~48 │  Columns, machines, conveyors          │
  │    Warehouse X=50~80│  Racks, pallets, cylinders             │
  │    Platform Z=+1.5  │  Elevated maintenance area X=15~27    │
  ├─── Level B1  Z=-2.5m ─── Loading Dock ─────────────────────┤
  │    X=0~60, Y=0~8    │  3 truck bays, pallets, drums          │
  └─────────────────────────────────────────────────────────────┘

  Vertical Connections:
    Ramp  R1  : B1 → G0   X=0~60, Y=5→25, rise=2.5m, run=20m (12.5%, 7.1°)
    Ramp  R2  : G0 → +1.5m X=15~27, Y=30→44, rise=1.5m, run=14m (10.7%, 6.1°)
    Ramp  R3  : Outdoor slope, Y=-8→0, Z=-1.2→0 (vehicle approach)
    Stair S1  : G0 → M1   X=5~8,   Y=28, 18 steps (center X=6.5)
    Stair S2  : G0 → M1   X=55~58, Y=28, 18 steps (center X=56.5)
    Stair S3  : M1 → M2   X=55~58, Y=34, 18 steps (center X=56.5)
    Stair S4  : M2 → RF   X=55~58, Y=45, 18 steps (center X=56.5)

  Navigation Route:
    Start (5,3,-2.0) → Ramp R1 → G0 main hall → navigate columns/machines
    → optional Ramp R2 (raised platform) → navigate to Stair S1 (6.5,28)
    → M1 catwalk/bridge → navigate east to S2 top area → Stair S3 (56.5,34)
    → M2 control room → Stair S4 (56.5,45) → Roof Platform → Goal (72,52,14.0)

  Vertical gain: 16.5m  Horizontal distance: ~100m  Complexity: HIGH

  Usage:
    python sim/scripts/view_scene.py factory_scene
    python -m mujoco.viewer sim/worlds/factory_scene.xml
-->
<mujoco model="mappilot_factory">

  <compiler angle="radian" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <visual>
    <headlight diffuse="0.55 0.55 0.55" ambient="0.40 0.40 0.40" specular="0 0 0"/>
    <rgba haze="0.12 0.18 0.25 1"/>
    <global azimuth="-42" elevation="-16" fovy="48"/>
  </visual>

  <asset>
    <material name="concrete"    rgba=".52 .52 .50 1" shininess="0.02" specular="0.05"/>
    <material name="floor_mat"   rgba=".35 .35 .33 1" shininess="0.06" specular="0.08"/>
    <material name="wall_mat"    rgba=".65 .62 .60 1" shininess="0.02" specular="0.05"/>
    <material name="stair_mat"   rgba=".50 .48 .45 1" shininess="0.05" specular="0.08"/>
    <material name="ramp_mat"    rgba=".42 .40 .22 1" shininess="0.05"/>
    <material name="column_mat"  rgba=".78 .80 .85 1" shininess="0.20" specular="0.30"/>
    <material name="machine_mat" rgba=".18 .30 .22 1" shininess="0.10" specular="0.15"/>
    <material name="conveyor_mat" rgba=".22 .22 .22 1"/>
    <material name="tank_mat"    rgba=".68 .70 .75 1" shininess="0.25" specular="0.35"/>
    <material name="shelf_mat"   rgba=".72 .42 .10 1"/>
    <material name="dock_mat"    rgba=".30 .28 .25 1" shininess="0.03"/>
    <material name="stripe_mat"  rgba=".88 .75 .08 1"/>
    <material name="container_mat" rgba=".18 .42 .65 1"/>
    <material name="barrel_mat"  rgba=".68 .18 .12 1"/>
    <material name="railing_mat" rgba=".65 .65 .68 1" shininess="0.15" specular="0.25"/>
    <material name="glass_mat"   rgba=".60 .80 .90 0.25"/>
    <material name="hvac_mat"    rgba=".72 .74 .78 1"/>
    <material name="caution_mat" rgba=".90 .70 .08 1"/>
    <material name="platform_mat" rgba=".42 .42 .38 1"/>
    <material name="robot_mat"   rgba=".18 .38 .76 1"/>
    <material name="lidar_mat"   rgba=".00 .78 .85 1"/>
    <material name="start_mat"   rgba=".15 .78 .28 0.90"/>
    <material name="goal_mat"    rgba=".90 .12 .12 0.90"/>
    <material name="pipe_mat"    rgba=".50 .52 .58 1" shininess="0.12" specular="0.20"/>
  </asset>

  <worldbody>

    <!-- ═══════════════════════════════════════════════════════════════
         OUTDOOR GROUND & PERIMETER
    ═══════════════════════════════════════════════════════════════ -->

    <geom name="outdoor_ground" type="plane" size="200 200 0.1"
          material="concrete" conaffinity="1" condim="3"/>

    <!-- Outdoor vehicle ramp R3 (approach from south, Z=-1.2→0) -->
    <!-- α=atan2(1.2,8)=0.1489rad, ramp_length=8.09m, half=4.045m -->
    <!-- Low end target: (30,-8,-1.2) → cy=-8+4.045*cos(0.1489)+0.12*sin(0.1489)=-8+4.026+0.018=-3.956, cz=-1.2+4.045*sin(0.1489)-0.12*cos(0.1489)=-1.2+0.602-0.119=-0.717 -->
    <geom name="ramp_r3" type="box"
          pos="30 -3.956 -0.717" size="30 4.045 0.12"
          euler="0.1489 0 0"
          material="concrete" conaffinity="1" condim="3"/>

    <!-- Outdoor stacked shipping containers (east yard) -->
    <geom name="cont_01" type="box" pos="88  8  1.25" size="3.0 1.20 1.25" material="container_mat" conaffinity="1"/>
    <geom name="cont_02" type="box" pos="88 12  1.25" size="3.0 1.20 1.25" material="container_mat" conaffinity="1"/>
    <geom name="cont_03" type="box" pos="88 16  1.25" size="3.0 1.20 1.25" material="container_mat" conaffinity="1"/>
    <geom name="cont_04" type="box" pos="88 20  1.25" size="3.0 1.20 1.25" rgba=".65 .30 .12 1" conaffinity="1"/>
    <geom name="cont_05" type="box" pos="88  8  3.75" size="3.0 1.20 1.25" rgba=".65 .30 .12 1" conaffinity="1"/>
    <geom name="cont_06" type="box" pos="88 12  3.75" size="3.0 1.20 1.25" material="container_mat" conaffinity="1"/>
    <geom name="cont_07" type="box" pos="88 16  3.75" size="3.0 1.20 1.25" rgba=".25 .55 .28 1" conaffinity="1"/>
    <geom name="cont_08" type="box" pos="96 10  1.25" size="3.0 1.20 1.25" rgba=".25 .55 .28 1" conaffinity="1"/>
    <geom name="cont_09" type="box" pos="96 14  1.25" size="3.0 1.20 1.25" material="container_mat" conaffinity="1"/>
    <geom name="cont_10" type="box" pos="96 10  3.75" size="3.0 1.20 1.25" rgba=".55 .30 .10 1" conaffinity="1"/>

    <!-- Outdoor oil drums (south yard) -->
    <geom name="drum_out_01" type="cylinder" pos="-6  8  0.45" size="0.32 0.45" material="barrel_mat" conaffinity="1"/>
    <geom name="drum_out_02" type="cylinder" pos="-6  9.8 0.45" size="0.32 0.45" material="barrel_mat" conaffinity="1"/>
    <geom name="drum_out_03" type="cylinder" pos="-6 11.6 0.45" size="0.32 0.45" material="barrel_mat" conaffinity="1"/>
    <geom name="drum_out_04" type="cylinder" pos="-6  8  1.35" size="0.32 0.45" material="barrel_mat" conaffinity="1"/>
    <geom name="drum_out_05" type="cylinder" pos="-6  9.8 1.35" size="0.32 0.45" material="barrel_mat" conaffinity="1"/>
    <geom name="drum_out_06" type="cylinder" pos="42 -8  0.45" size="0.32 0.45" rgba=".70 .68 .10 1" conaffinity="1"/>
    <geom name="drum_out_07" type="cylinder" pos="44 -8  0.45" size="0.32 0.45" rgba=".70 .68 .10 1" conaffinity="1"/>
    <geom name="drum_out_08" type="cylinder" pos="46 -8  0.45" size="0.32 0.45" rgba=".70 .68 .10 1" conaffinity="1"/>

    <!-- Guard booth + barrier (south entrance) -->
    <geom name="booth_walls" type="box" pos="70 -4 1.20" size="1.50 1.50 1.20" material="wall_mat" conaffinity="1"/>
    <geom name="booth_roof"  type="box" pos="70 -4 2.60" size="1.90 1.90 0.20" material="wall_mat" conaffinity="1"/>
    <geom name="barrier_W"   type="box" pos="54 -1 0.60" size="0.15 0.80 0.60" material="railing_mat" conaffinity="1"/>
    <geom name="barrier_E"   type="box" pos="66 -1 0.60" size="0.15 0.80 0.60" material="railing_mat" conaffinity="1"/>
    <!-- barrier arm -->
    <geom name="barrier_arm" type="box" pos="60 -0.8 1.15" size="6.0 0.06 0.06" rgba=".85 .20 .20 1" conaffinity="0" contype="0"/>

    <!-- ═══════════════════════════════════════════════════════════════
         BUILDING OUTER SHELL  (80m × 55m × 13.5m)
    ═══════════════════════════════════════════════════════════════ -->

    <!-- South wall — full height (0.3m thick) -->
    <geom name="wall_S"  type="box" pos="40 0.15 6.75" size="40 0.15 6.75" material="wall_mat" conaffinity="1"/>
    <!-- North wall -->
    <geom name="wall_N"  type="box" pos="40 54.85 6.75" size="40 0.15 6.75" material="wall_mat" conaffinity="1"/>
    <!-- West wall -->
    <geom name="wall_W"  type="box" pos="0.15 27.5 6.75" size="0.15 27.5 6.75" material="wall_mat" conaffinity="1"/>
    <!-- East wall -->
    <geom name="wall_E"  type="box" pos="79.85 27.5 6.75" size="0.15 27.5 6.75" material="wall_mat" conaffinity="1"/>

    <!-- Interior dividing wall Main Hall | Warehouse at X=50 -->
    <!-- Door passage: Y=30~40 (10m wide) -->
    <geom name="wall_int_S"      type="box" pos="50 15.0 4.50" size="0.15 15.0 4.50" material="wall_mat" conaffinity="1"/>
    <geom name="wall_int_N"      type="box" pos="50 47.5 4.50" size="0.15  7.5 4.50" material="wall_mat" conaffinity="1"/>
    <geom name="wall_int_lintel" type="box" pos="50 35.0 8.55" size="0.15  5.0 0.45" material="wall_mat" conaffinity="1"/>

    <!-- Partial upper continuation of interior wall (M1→M2 level) -->
    <geom name="wall_int_M1S" type="box" pos="50 15.0 9.0" size="0.15 15.0 4.50" material="wall_mat" conaffinity="1"/>
    <geom name="wall_int_M1N" type="box" pos="50 47.5 9.0" size="0.15  7.5 4.50" material="wall_mat" conaffinity="1"/>

    <!-- ═══════════════════════════════════════════════════════════════
         LEVEL B1: LOADING DOCK  (Z = -2.5m)
         Area: X=0~60, Y=0~8 at Z=-2.5
    ═══════════════════════════════════════════════════════════════ -->

    <!-- Dock floor (flat section, 3 truck bays) -->
    <geom name="dock_floor" type="box" pos="30 4.0 -2.60" size="30 4.0 0.10"
          material="dock_mat" conaffinity="1" condim="3"/>

    <!-- Dock side walls -->
    <geom name="dock_wall_W" type="box" pos="0.30 4.0 -1.25" size="0.15 4.0 1.25" material="wall_mat" conaffinity="1"/>
    <geom name="dock_wall_E" type="box" pos="59.70 4.0 -1.25" size="0.15 4.0 1.25" material="wall_mat" conaffinity="1"/>

    <!-- Bay stripe markers (3 bays, yellow lines) -->
    <geom name="stripe_bay1" type="box" pos="14 6.5 -2.49" size="0.12 2.0 0.01" material="stripe_mat" conaffinity="0" contype="0"/>
    <geom name="stripe_bay2" type="box" pos="31 6.5 -2.49" size="0.12 2.0 0.01" material="stripe_mat" conaffinity="0" contype="0"/>
    <geom name="stripe_bay3" type="box" pos="48 6.5 -2.49" size="0.12 2.0 0.01" material="stripe_mat" conaffinity="0" contype="0"/>

    <!-- Dock equipment: pallets + crates + drums -->
    <geom name="dock_pallet1" type="box" pos="9  2.5 -2.35" size="0.65 0.45 0.08" material="shelf_mat" conaffinity="1"/>
    <geom name="dock_crate1"  type="box" pos="9  2.5 -2.00" size="0.60 0.42 0.28" material="shelf_mat" conaffinity="1"/>
    <geom name="dock_pallet2" type="box" pos="9  3.8 -2.35" size="0.65 0.45 0.08" material="shelf_mat" conaffinity="1"/>
    <geom name="dock_crate2"  type="box" pos="9  3.8 -2.00" size="0.60 0.42 0.28" material="shelf_mat" conaffinity="1"/>
    <geom name="dock_pallet3" type="box" pos="25 2.5 -2.35" size="0.65 0.45 0.08" material="shelf_mat" conaffinity="1"/>
    <geom name="dock_crate3"  type="box" pos="25 2.5 -2.00" size="0.60 0.42 0.28" rgba=".60 .38 .12 1" conaffinity="1"/>
    <geom name="dock_drum1"   type="cylinder" pos="43 2.0 -2.05" size="0.30 0.45" material="barrel_mat" conaffinity="1"/>
    <geom name="dock_drum2"   type="cylinder" pos="44.8 2.0 -2.05" size="0.30 0.45" material="barrel_mat" conaffinity="1"/>
    <geom name="dock_drum3"   type="cylinder" pos="43 3.6 -2.05" size="0.30 0.45" rgba=".55 .55 .18 1" conaffinity="1"/>
    <!-- Forklift (simplified) -->
    <geom name="fork_body"    type="box" pos="52 3 -2.05" size="0.80 0.55 0.45" rgba=".90 .62 .05 1" conaffinity="1"/>
    <geom name="fork_cabin"   type="box" pos="52 3 -1.25" size="0.40 0.40 0.35" rgba=".90 .62 .05 1" conaffinity="1"/>
    <geom name="fork_arm_L"   type="box" pos="52 2.25 -2.45" size="0.06 0.06 0.06" rgba=".40 .40 .40 1" conaffinity="0" contype="0"/>
    <geom name="fork_arm_R"   type="box" pos="52 3.75 -2.45" size="0.06 0.06 0.06" rgba=".40 .40 .40 1" conaffinity="0" contype="0"/>

    <!-- ═══════════════════════════════════════════════════════════════
         RAMP R1: Loading Dock → G0
         B1(Y=5,Z=-2.5) → G0(Y=25,Z=0)   rise=2.5m, run=20m
         α=atan2(2.5,20)=0.1244rad, ramp_length=20.16m, half=10.08m
         cx=30, cy=30-10.08*cos(0.1244)-0.15*sin(0.1244)=30-10.016-0.019=19.965→ cy=15.021
         cz=-2.5+10.08*sin(0.1244)-0.15*cos(0.1244)=-2.5+1.255-0.149=-1.394
    ═══════════════════════════════════════════════════════════════ -->
    <geom name="ramp_r1" type="box"
          pos="30 15.021 -1.394" size="29.5 10.08 0.15"
          euler="0.1244 0 0"
          material="ramp_mat" conaffinity="1" condim="3"/>
    <!-- Ramp safety rails -->
    <geom name="r1_rail_W" type="box" pos="0.60 15.021 -0.694" size="0.10 10.08 0.50"
          euler="0.1244 0 0" material="railing_mat" conaffinity="0" contype="0"/>
    <geom name="r1_rail_E" type="box" pos="59.40 15.021 -0.694" size="0.10 10.08 0.50"
          euler="0.1244 0 0" material="railing_mat" conaffinity="0" contype="0"/>
    <!-- Caution stripes on ramp surface -->
    <geom name="r1_stripe1" type="box" pos="15 10 -2.10" size="0.08 0.50 0.02"
          euler="0.1244 0 0" material="stripe_mat" conaffinity="0" contype="0"/>
    <geom name="r1_stripe2" type="box" pos="30 15 -1.25" size="0.08 0.50 0.02"
          euler="0.1244 0 0" material="stripe_mat" conaffinity="0" contype="0"/>

    <!-- ═══════════════════════════════════════════════════════════════
         LEVEL G0: MAIN PRODUCTION FLOOR (Z=0)
    ═══════════════════════════════════════════════════════════════ -->

    <!-- Main hall floor: X=0~50, Y=25~54 -->
    <geom name="floor_G0_hall"  type="box" pos="25 39.5 -0.075" size="25 14.5 0.075"
          material="floor_mat" conaffinity="1" condim="3"/>
    <!-- Warehouse floor: X=50~80, Y=0~54 -->
    <geom name="floor_G0_wh"    type="box" pos="65 27.0 -0.075" size="15 27.0 0.075"
          material="floor_mat" conaffinity="1" condim="3"/>
    <!-- Transition / corridor floor Y=25~28, X=0~50 -->
    <geom name="floor_G0_trans" type="box" pos="25 26.5 -0.075" size="25  1.5 0.075"
          material="floor_mat" conaffinity="1" condim="3"/>

    <!-- ── STRUCTURAL COLUMNS (5×4 grid on main hall + 2×4 on warehouse) ── -->
    <!-- Main hall: X=10,22,34,46 × Y=32,40,48 = 4×3=12 columns -->
    <geom name="col_A1" type="cylinder" pos="10 32 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_A2" type="cylinder" pos="10 40 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_A3" type="cylinder" pos="10 48 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_B1" type="cylinder" pos="22 32 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_B2" type="cylinder" pos="22 40 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_B3" type="cylinder" pos="22 48 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_C1" type="cylinder" pos="34 32 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_C2" type="cylinder" pos="34 40 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_C3" type="cylinder" pos="34 48 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_D1" type="cylinder" pos="46 32 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_D2" type="cylinder" pos="46 40 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_D3" type="cylinder" pos="46 48 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <!-- Warehouse: X=58,70 × Y=12,24,36,48 = 2×4=8 columns -->
    <geom name="col_E1" type="cylinder" pos="58 12 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_E2" type="cylinder" pos="58 24 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_E3" type="cylinder" pos="58 36 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_E4" type="cylinder" pos="58 48 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_F1" type="cylinder" pos="70 12 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_F2" type="cylinder" pos="70 24 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_F3" type="cylinder" pos="70 36 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>
    <geom name="col_F4" type="cylinder" pos="70 48 6.75" size="0.35 6.75" material="column_mat" conaffinity="1"/>

    <!-- ── LARGE MACHINES on Main Hall (4 presses + 4 tanks) ── -->
    <!-- Industrial press 1 (large): X=8~14, Y=34~40, Z=0~3 -->
    <geom name="mach_press1"  type="box" pos="11 37 1.50" size="3.0 3.0 1.50" material="machine_mat" conaffinity="1"/>
    <geom name="mach_press1T" type="box" pos="11 37 3.40" size="1.80 1.80 0.40" material="machine_mat" conaffinity="1"/>
    <!-- Industrial press 2: X=8~14, Y=43~49 -->
    <geom name="mach_press2"  type="box" pos="11 46 1.50" size="3.0 3.0 1.50" material="machine_mat" conaffinity="1"/>
    <geom name="mach_press2T" type="box" pos="11 46 3.40" size="1.80 1.80 0.40" material="machine_mat" conaffinity="1"/>
    <!-- Stamping machine: X=26~30, Y=43~49 -->
    <geom name="mach_stamp1"  type="box" pos="28 46 1.00" size="2.0 3.0 1.00" material="machine_mat" conaffinity="1"/>
    <geom name="mach_stamp2"  type="box" pos="28 46 2.20" size="0.80 1.20 0.50" rgba=".25 .45 .28 1" conaffinity="1"/>
    <!-- Robotic arm station: X=38~43, Y=43~49 -->
    <geom name="mach_arm_base" type="cylinder" pos="40 46 0.60" size="0.80 0.60" material="machine_mat" conaffinity="1"/>
    <geom name="mach_arm_body" type="cylinder" pos="40 46 1.80" size="0.35 0.60" material="machine_mat" conaffinity="1"/>
    <geom name="mach_arm_head" type="box" pos="41.5 46 2.50" size="1.50 0.25 0.25" rgba=".25 .45 .28 1" conaffinity="1"/>

    <!-- Large storage tanks (cylinders): near north wall -->
    <geom name="tank1" type="cylinder" pos="6  29 2.00" size="2.00 2.00" material="tank_mat" conaffinity="1"/>
    <geom name="tank2" type="cylinder" pos="6  35 2.00" size="2.00 2.00" material="tank_mat" conaffinity="1"/>
    <geom name="tank3" type="cylinder" pos="6  41 2.00" size="1.50 1.80" rgba=".62 .58 .55 1" conaffinity="1"/>
    <geom name="tank4" type="cylinder" pos="6  47 1.50" size="1.50 1.50" rgba=".62 .58 .55 1" conaffinity="1"/>
    <!-- Pipe connecting tanks -->
    <geom name="pipe_t12" type="cylinder" pos="6 32 3.50" size="0.15 1.50" material="pipe_mat" conaffinity="0" contype="0"/>
    <geom name="pipe_t23" type="cylinder" pos="6 38 3.50" size="0.15 1.50" material="pipe_mat" conaffinity="0" contype="0"/>
    <geom name="pipe_horiz" type="box" pos="6 38 4.20" size="0.12 6.0 0.12" material="pipe_mat" conaffinity="0" contype="0"/>

    <!-- ── CONVEYOR BELT LINES ── -->
    <!-- Conveyor 1: runs along X direction (support + belt) -->
    <geom name="conv1_support" type="box" pos="27 33 0.60" size="12 0.40 0.60" material="conveyor_mat" conaffinity="1"/>
