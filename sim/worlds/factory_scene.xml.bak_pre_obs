          rgba=".90 .12 .12 0.85" conaffinity="0" contype="0"/>

    <!-- ═══════════════════════════════════════════════════════════════
         ROBOT PLACEHOLDER
         Start pos = (5, 3, -2.0)  [0.5m above B1 dock floor at Z=-2.5]
         body names: base_link / lidar_link — bridge depends on these names
    ═══════════════════════════════════════════════════════════════ -->
    <body name="base_link" pos="5.0 3.0 -2.0">
      <freejoint name="robot_root"/>

      <!-- Chassis (replace with self-developed URDF) -->
      <geom name="chassis" type="box" size="0.42 0.28 0.10"
            material="robot_mat" mass="22" conaffinity="1"/>
      <!-- Simplified legs -->
      <geom name="leg_fl" type="capsule" size="0.030" fromto=" 0.30  0.20 -.10  0.30  0.20 -.40" rgba=".12 .32 .72 1" mass="0.8" conaffinity="1"/>
      <geom name="leg_fr" type="capsule" size="0.030" fromto=" 0.30 -.20 -.10  0.30 -.20 -.40" rgba=".12 .32 .72 1" mass="0.8" conaffinity="1"/>
      <geom name="leg_rl" type="capsule" size="0.030" fromto="-.30  0.20 -.10 -.30  0.20 -.40" rgba=".12 .32 .72 1" mass="0.8" conaffinity="1"/>
      <geom name="leg_rr" type="capsule" size="0.030" fromto="-.30 -.20 -.10 -.30 -.20 -.40" rgba=".12 .32 .72 1" mass="0.8" conaffinity="1"/>

      <!-- Livox MID-360 mount -->
      <body name="lidar_link" pos="0 0 0.22">
        <geom name="lidar_housing" type="cylinder" size="0.058 0.046"
              material="lidar_mat" mass="0.50" conaffinity="0"/>
        <geom name="lidar_pole"    type="capsule"  size="0.016"
              fromto="0 0 -0.01  0 0 -0.14" rgba=".28 .28 .28 1" mass="0.08" conaffinity="0"/>
        <site name="lidar_site" pos="0 0 0" size="0.001"/>
      </body>
      <!-- Forward direction indicator (yellow) -->
      <geom name="dir_arrow" type="capsule" size="0.020"
            fromto="0.05 0 0.12  0.44 0 0.12" rgba=".95 .75 .05 1" conaffinity="0"/>

      <inertial pos="0 0 0" mass="22" diaginertia="0.78 1.18 1.18"/>
    </body>

  </worldbody>

  <!-- ═══════════════════════════════════════════════════════════════════
       LiDAR SENSOR (mujoco_ray_caster plugin)
       Uncomment on server after MUJOCO_PLUGIN_PATH is set correctly.
       Local Windows verification: keep commented out.
  ═══════════════════════════════════════════════════════════════════ -->
  <!--
  <extension>
    <plugin plugin="mujoco.sensor.ray_caster_lidar"/>
  </extension>
  <sensor>
    <plugin name="lidar_mid360" plugin="mujoco.sensor.ray_caster_lidar"
            objtype="site" objname="lidar_site" cutoff="50">
      <config key="fov_h"             value="360"/>
      <config key="fov_v"             value="59"/>
      <config key="size"              value="360 16"/>
      <config key="dis_range"         value="0.1 50"/>
      <config key="sensor_data_types" value="pos_w noise_data"/>
      <config key="num_thread"        value="4"/>
    </plugin>
  </sensor>
  -->

</mujoco>
