    <light name="rf_light" pos="65 47 16.0" dir="0 0 -1" diffuse=".50 .50 .50" castshadow="false"/>

    <!-- ═══════════════════════════════════════════════════════════════
         START / GOAL MARKERS
    ═══════════════════════════════════════════════════════════════ -->

    <!-- Start: Loading Dock B1 at (5, 3) -->
    <geom name="start_disk" type="cylinder" pos="5 3 -2.49" size="0.80 0.01"
          material="start_mat" conaffinity="0" contype="0"/>
    <geom name="start_pole" type="cylinder" pos="5 3 -2.49" size="0.03 1.00"
          rgba=".15 .78 .28 0.8" conaffinity="0" contype="0"/>

    <!-- Goal: Roof Platform RF at (72, 52) -->
    <geom name="goal_disk"  type="cylinder" pos="72 52 13.51" size="0.80 0.01"
          material="goal_mat" conaffinity="0" contype="0"/>
    <geom name="goal_pole"  type="cylinder" pos="72 52 13.51" size="0.03 1.20"
          rgba=".90 .12 .12 0.9" conaffinity="0" contype="0"/>
