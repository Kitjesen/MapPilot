    <!-- α=atan2(1.5,14)=0.1066rad, half_len=sqrt(7²+0.75²)=7.040m -->
    <!-- Low end target: (21,30,0) → cy=30+7.040*cos(0.1066)+0.12*sin(0.1066)=30+7.005+0.013=37.018, cz=7.040*sin(0.1066)-0.12*cos(0.1066)=0.750-0.120=0.630 -->
