    <light name="hall_2"   pos="30 44  4.0" dir="0 0 -1" diffuse=".70 .70 .65" castshadow="false"/>
    <light name="hall_3"   pos="42 36  4.0" dir="0 0 -1" diffuse=".65 .65 .60" castshadow="false"/>
